{
  "compilerOptions": {
    "module": "esnext",                // Use ES modules
    "rootDir": "./",                // Source directory
    "outDir": "./dist",                // Output directory
    "moduleResolution": "node",       // Resolve modules like Node.js
    "esModuleInterop": true,          // Support CommonJS imports
    "strict": true,                   // Enforce best practices
    "declaration": true,              // Generate type declarations
    "declarationMap": true,           // Source map for .d.ts files
    "sourceMap": true,                // Source map for debugging
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
}
